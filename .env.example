NODE_ENV=development
PORT=3000

# Mongo connection — must point at a replica-set deployment.
# Local dev uses the bundled docker-compose.yml (run: docker compose up -d).
# Prod: ensure the URI carries retryWrites=true&w=majority&tls=true (Atlas does this by default).
MONGO_URI=mongodb://localhost:27017/ecommerce?replicaSet=rs0

# JWT — secret must be at least 32 characters (boot fails otherwise).
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Auth knobs. BCRYPT_ROUNDS=12 recommended for production.
BCRYPT_ROUNDS=10
# OTP_DUMMY=true accepts "1234" for any verify. Boot will FAIL if true in production.
OTP_DUMMY=true
OTP_EXPIRY_MIN=10
RESET_TOKEN_EXPIRY_MIN=30

# CORS_ORIGIN: comma-separated list or single origin (e.g. https://app.example.com).
# Boot will FAIL if "*" in production.
CORS_ORIGIN=*

# TRUST_PROXY: number of reverse-proxy hops in front of this app (e.g. 1 behind a single LB).
# Required for correct req.ip when behind a load balancer — rate limiting depends on it.
# 0 disables. Boot will WARN if 0 in production.
TRUST_PROXY=0
