NODE_ENV=development
PORT=3000

# Mongo connection — must point at a replica-set deployment.
# Local dev uses the bundled docker-compose.yml (run: docker compose up -d).
MONGO_URI=mongodb://localhost:27017/ecommerce?replicaSet=rs0

# JWT — secret must be at least 32 characters (boot fails otherwise).
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Auth knobs
BCRYPT_ROUNDS=10
OTP_DUMMY=true
OTP_EXPIRY_MIN=10
RESET_TOKEN_EXPIRY_MIN=30

CORS_ORIGIN=*
